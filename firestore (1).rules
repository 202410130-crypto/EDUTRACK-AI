rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: just check if user is authenticated ──
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Helper: safely get user role with error handling ──
    function userRole() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    function isAdmin()       { return userRole() == 'admin'; }
    function isTeacher()     { return userRole() == 'teacher'; }
    function isCoordinator() { return userRole() == 'coordinator'; }
    function isTeacherOrAdmin() { return isTeacher() || isAdmin(); }
    function isStaff() { return isTeacher() || isAdmin() || isCoordinator(); }

    // ── Users ──
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Pending users ──
    match /pending_users/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Classes ──
    match /classes/{classId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Enrollments ──
    match /enrollments/{id} {
      allow read:   if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin();
      allow delete: if isTeacherOrAdmin();
    }

    // ── Grades ──
    match /grades/{id} {
      allow read:   if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin();
      allow delete: if isTeacherOrAdmin();
    }

    // ── Risk assessments ──
    match /risk_assessments/{id} {
      allow read:   if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin();
      allow delete: if isTeacherOrAdmin();
    }

    // ── Reports ──
    match /reports/{id} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }
  }
}
